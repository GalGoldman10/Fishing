{
  "expo": {
    "name": "FishGuide AI",
    "slug": "fishguide-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fishguideai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fishguide.ai",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "FishGuide needs your location to show nearby fishing spots and conditions.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "FishGuide uses location for trip planning and nearby spot discovery."
      }
    },
    "android": {
      "package": "com.fishguide.ai",
      "adaptiveIcon": {
        "backgroundColor": "#0A4D68",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#0A4D68"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FishGuide needs your location to show nearby fishing spots."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#0A4D68"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/Fishing"
    },
    "extra": {
      "eas": {
        "projectId": "your-eas-project-id"
      }
    }
  }
}
