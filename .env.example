# Client-safe (Expo public) — prefix with EXPO_PUBLIC_
EXPO_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-anon-key
EXPO_PUBLIC_MAP_PROVIDER=react-native-maps
EXPO_PUBLIC_MAP_TOKEN=
EXPO_PUBLIC_USE_MOCK_DATA=true
EXPO_PUBLIC_APP_ENV=development

# Backend-only — configure as Supabase secrets, NEVER in client bundle
# OPENAI_API_KEY=                    # Required for AI synthesis
# OPENAI_MODEL=gpt-4.1-mini
# WEB_SEARCH_PROVIDER=auto           # auto | tavily | serper | jina
# TAVILY_API_KEY=                    # Recommended: enables multi-source web research
# SERPER_API_KEY=                    # Google search fallback
# MARINE_CONDITIONS_PROVIDER=open-meteo  # open-meteo (free, no key) | custom
# MARINE_API_KEY=                    # Only needed for a premium marine provider
# WEATHER_API_KEY=                   # Only needed for a premium weather provider
# TIDE_API_KEY=                      # Only needed for a premium tide provider
# SUPABASE_SERVICE_ROLE_KEY=
