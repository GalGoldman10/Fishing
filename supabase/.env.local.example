# Copy to supabase/.env.local for local edge function testing:
#   cp supabase/.env.local.example supabase/.env.local
#
# Then run:
#   supabase functions serve fishing-assistant --env-file supabase/.env.local

OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4.1-mini

# Optional — enables web search inside ChatGPT answers
WEB_SEARCH_PROVIDER=auto
# TAVILY_API_KEY=tvly-...

# Auto-filled when using `supabase start` locally:
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key
